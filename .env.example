# Flask Configuration
SECRET_KEY=replace_with_a_secure_random_string_in_production
FLASK_APP=app.py
FLASK_ENV=development

# Database Configuration (PostgreSQL ONLY)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swm_db

# Google Maps JavaScript API Key
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Upload Settings
MAX_CONTENT_LENGTH=5242880

# Brevo Transactional Email API
# Get your API key from: https://app.brevo.com → Transactional → Settings → API Keys
BREVO_API_KEY=
MAIL_FROM=
MAIL_FROM_NAME=Smart Waste Management System
